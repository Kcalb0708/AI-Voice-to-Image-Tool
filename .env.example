# Backend
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Cloud ASR provider. The default client expects an OpenAI-compatible
# multipart transcription endpoint that returns {"text": "..."}.
ASR_API_URL=https://api.openai.com/v1
ASR_API_KEY=replace-me
ASR_MODEL=gpt-4o-mini-transcribe
ASR_LANGUAGE=zh
ASR_RESPONSE_FORMAT=json
ASR_TIMEOUT_SECONDS=45

# LLM provider through LangChain init_chat_model. Use an OpenAI-compatible base URL.
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=replace-me
LLM_MODEL=gpt-4.1-mini
LLM_TIMEOUT_SECONDS=45
LLM_STRUCTURED_OUTPUT_METHOD=json_schema
